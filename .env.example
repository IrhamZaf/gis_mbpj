# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME="GIS MBPJ"
APP_ENV=local
APP_KEY=base64:ufqB1VZMDPuTQInWGfTu0Ni6j/VVHpwQJ0nx0YTdzh8=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
APP_TIMEZONE=Asia/Kuala_Lumpur

APP_LOCALE=ms
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

# -----------------------------------------------------------------------------
# Security / hashing
# -----------------------------------------------------------------------------
BCRYPT_ROUNDS=12

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Database (MySQL — recommended for this project)
# -----------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=u894365806_gis_mbpj
DB_USERNAME=u894365806_gis_mbpj
DB_PASSWORD=Mbpj@123

# Optional: SQLite (enable only if pdo_sqlite is installed)
# DB_CONNECTION=sqlite
# DB_DATABASE="${APP_PATH}/database/database.sqlite"

# -----------------------------------------------------------------------------
# Session (GIS uses auth; database driver matches migrations)
# -----------------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# -----------------------------------------------------------------------------
# Cache & queue
# -----------------------------------------------------------------------------
CACHE_STORE=database
# CACHE_PREFIX=

QUEUE_CONNECTION=database

# -----------------------------------------------------------------------------
# Files / uploads (incident & survey files use public disk)
# -----------------------------------------------------------------------------
FILESYSTEM_DISK=local

# -----------------------------------------------------------------------------
# Broadcasting (optional)
# -----------------------------------------------------------------------------
BROADCAST_CONNECTION=log
# BROADCAST_DRIVER=log
# PUSHER_APP_ID=
# PUSHER_APP_KEY=
# PUSHER_APP_SECRET=
# PUSHER_HOST=
# PUSHER_PORT=443
# PUSHER_SCHEME=https
# PUSHER_APP_CLUSTER=mt1

# -----------------------------------------------------------------------------
# Redis (optional — only if you switch cache/queue/session to redis)
# -----------------------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MEMCACHED_HOST=127.0.0.1

# -----------------------------------------------------------------------------
# Mail (set real values when you send email)
# -----------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@mbpj.gov.my"
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# AWS / S3 (optional)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# -----------------------------------------------------------------------------
# Vite (front-end)
# -----------------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"